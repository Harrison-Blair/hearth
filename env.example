# Example .env for the personal assistant.
#
# Copy to `.env` (or use the monitor TUI's Env tab) to override config.yaml
# values per machine without editing the committed YAML. The monitor TUI merges
# this file into the daemon's environment at (re)start; precedence is
# process env < .env < the TUI's in-session config changes.
#
# Keys are pydantic-settings ASSISTANT_* vars: nested config is joined with `__`
# (e.g. ASSISTANT_LLM__MODEL maps to llm.model). The Env tab's
# "Add missing"/"Remove extra" buttons reconcile your .env against this file.

# --- LLM (Ollama) ---
ASSISTANT_LLM__MODEL=qwen2.5:3b-instruct
ASSISTANT_LLM__HOST=http://localhost:11434

# --- LLM (OpenCode Zen) ---
# Switch the primary by setting ASSISTANT_LLM__PROVIDER=opencode-zen. Get a key
# at https://opencode.ai/auth. Any OpenAI-compatible Zen model id works for
# ASSISTANT_LLM__MODEL (deepseek-v4-flash-free is $0 in/$0 out). Set
# ASSISTANT_LLM__FALLBACK=ollama to fall back to the local model on failure.
ASSISTANT_LLM__PROVIDER=ollama
ASSISTANT_LLM__API_KEY=
ASSISTANT_LLM__BASE_URL=https://opencode.ai/zen/v1
ASSISTANT_LLM__FALLBACK=
ASSISTANT_LLM__FALLBACK_MODEL=
ASSISTANT_LLM__MAX_RETRIES=2

# --- Wake word ---
ASSISTANT_WAKE__MODEL_PATH=models/wake/hey_assistant.onnx
ASSISTANT_WAKE__PHRASE=hey assistant
ASSISTANT_WAKE__THRESHOLD=0.6

# --- Speech-to-text ---
ASSISTANT_STT__MODEL=base.en

# --- Audio ---
ASSISTANT_AUDIO__OUTPUT_VOLUME=0.5

# --- Recorder ---
ASSISTANT_RECORDER__MAX_MS=30000    # hard cap on utterance length (room for the verify loop)

# --- Agent / verify loop ---
ASSISTANT_AGENT__TURN_TIMEOUT_S=45.0  # whole-turn budget; fits the verify loop + one reject re-loop
ASSISTANT_VERIFY__ENABLED=true        # master kill switch; off = today's single-pass behavior
ASSISTANT_VERIFY__SPOKEN_FEEDBACK=true  # speak "let me double check" fillers on a reject
# Advanced verify knobs (defaults are sensible; uncomment to override):
# ASSISTANT_VERIFY__PRE=true              # pre-tool gate: review pick+args before the skill runs
# ASSISTANT_VERIFY__POST=true             # post-tool check: review the answer before speech
# ASSISTANT_VERIFY__MAX_VERIFY_ROUNDS=2   # per-stage reject sub-cap within the turn's tool rounds
# Advanced (config.yaml only): agent.max_tool_rounds.

# --- Logging ---
ASSISTANT_LOGGING__LEVEL=INFO
