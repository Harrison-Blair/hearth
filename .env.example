# Credentials for the personal assistant.
#
# Copy to `.env` and fill in the keys you use. Non-secret tunables (models,
# hosts, thresholds) live in config.yaml — only API keys belong here.

# --- OpenRouter (provider: openrouter) ---
# Get a key at https://openrouter.ai/keys
ASSISTANT_LLM__OPENROUTER_API_KEY=

# --- OpenCode Zen (provider: opencode_zen) ---
# Get a key at https://opencode.ai/auth
ASSISTANT_LLM__OPENCODE_ZEN_API_KEY=

# --- Web search: Tavily ---
# Get a key at https://tavily.com
ASSISTANT_WEB_SEARCH__TAVILY_API_KEY=

# --- Web search: Exa ---
# Get a key at https://exa.ai
ASSISTANT_WEB_SEARCH__EXA_API_KEY=
